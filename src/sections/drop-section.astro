---
import '../styles/cards.css';
import SectionHeader from '../components/SectionHeader.astro';
import UrgencyWidget from '../components/UrgencyWidget.astro';
---

<section class="drop-section">
  <div class="container">
    <SectionHeader class="drop-header" eyebrow="Edición limitada" title="Lo nuevo" dark>
      <UrgencyWidget />
    </SectionHeader>
    <p class="drop-description">
      Los más recientes. Una vez que se acaben, no vuelven.
    </p>
    <div id="drop-grid" class="drop-grid"></div>
  </div>
</section>

<style>
  .drop-section {
    background: var(--carbon-900);
    padding: 72px 0;
    border-top: 2px solid var(--carbon-800);
  }

  .drop-header {
    margin-bottom: 16px;
  }

  .drop-description {
    font-size: 14px;
    color: var(--carbon-300);
    margin-bottom: 32px;
    max-width: 480px;
  }

  .drop-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    min-height: 200px;
  }

  @media (min-width: 750px) {
    .drop-grid {
      grid-template-columns: repeat(2, 360px);
    }
  }
</style>

<style is:global>
  .drop-section .sheet-card {
    border-color: var(--carbon-700);
  }

  .drop-section .sc-info {
    background: var(--carbon-800);
    border-top-color: var(--carbon-700);
  }

  .drop-section .sc-name,
  .drop-section .sc-price {
    color: var(--bone-50);
  }

  .drop-section .sc-sub {
    color: var(--carbon-300);
  }

  .drop-section .sc-size {
    border-color: var(--carbon-600);
    color: var(--bone-200);
    background: transparent;
  }

  .drop-section .sc-size.active {
    background: var(--bone-50);
    color: var(--carbon-900);
    border-color: var(--bone-50);
  }

  .drop-section .sc-colordot {
    border-color: rgba(255,255,255,0.25);
  }

  .drop-section .sc-colordot.active {
    outline-color: var(--bone-50);
  }
</style>

<script>
  import { initDropCards } from '../scripts/sheet-products.ts';
  initDropCards('drop-grid', 2);
</script>
