---
import '../styles/cards.css';
import SectionHeader from '../components/SectionHeader.astro';
---

<section class="product-grid-section">
  <div class="container">
    <SectionHeader class="grid-header" eyebrow="La colección" title="Esenciales">
      <a href="/tienda" class="btn ghost sm">Ver todo</a>
    </SectionHeader>
    <div id="home-grid" class="product-grid"></div>
    <div class="grid-footer flex-row">
      <a href="/tienda" class="btn">Ver colección completa</a>
    </div>
  </div>
</section>

<style>
  .product-grid-section {
    background: var(--bg);
    padding: 72px 0;
  }

  .grid-header {
    margin-bottom: 32px;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    min-height: 200px;
  }

  .grid-footer {
    margin-top: 40px;
    justify-content: center;
  }

  @media (min-width: 750px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
</style>

<script>
  import { initHomeCards } from '../scripts/sheet-products.ts';
  initHomeCards('home-grid', 4);
</script>
