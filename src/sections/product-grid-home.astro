---
---

<section class="product-grid-section">
  <div class="container">
    <div class="section-header flex-row">
      <div class="flex-column header-left">
        <span class="eyebrow">La colección</span>
        <h2 class="section-title">Esenciales</h2>
      </div>
      <a href="/tienda" class="btn ghost sm">Ver todo</a>
    </div>
    <div id="home-grid" class="product-grid"></div>
    <div class="grid-footer flex-row">
      <a href="/tienda" class="btn">Ver colección completa</a>
    </div>
  </div>
</section>

<style>
  .product-grid-section {
    background: var(--bg);
    padding: 72px 0;
  }

  .section-header {
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 32px;
  }

  .header-left {
    align-items: flex-start;
    gap: 4px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--carbon-300);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 5vw, 44px);
    line-height: 0.95;
    color: var(--carbon-900);
    letter-spacing: -0.01em;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    min-height: 200px;
  }

  .grid-footer {
    margin-top: 40px;
    justify-content: center;
  }

  @media (min-width: 750px) {
    .product-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
</style>

<script>
  import { initHomeCards } from '../scripts/sheet-products.ts';
  initHomeCards('home-grid', 4);
</script>
