<section class="hero-section">
  <div class="container hero-inner">

    <div class="hero-text">
      <span class="hero-eyebrow">Drop 03 · Edición Limitada</span>
      <h1 class="hero-title">Bóxers<br />que no te<br />fallan.</h1>
      <p class="hero-subtitle">Microfibra 100%, costuras planas, elástico jacquard.<br />Fit honesto que aguanta el día.</p>
      <div class="hero-actions flex-row">
        <a href="/producto/boxer-pima-oliva" class="hero-btn">Comprar Drop 03</a>
        <a href="/tienda" class="hero-btn outlined">Ver colección</a>
      </div>
    </div>

    <div class="hero-product">
      <img src="/img/logo-mark.avif" alt="MacV Wear" class="stamp-img" />
    </div>

  </div>
</section>

<style>
  .hero-section {
    background: var(--carbon-900);
    padding: 80px 0 80px;
    border-bottom: 2px solid var(--carbon-800);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
    align-items: center;
  }

  /* ── Texto ── */
  .hero-text {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--blood-600);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(64px, 10vw, 132px);
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    color: var(--bone-50);
  }

  .hero-subtitle {
    font-size: 15px;
    color: var(--bone-400);
    line-height: 1.65;
  }

  /* ── Botones ── */
  .hero-actions {
    gap: 12px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .hero-btn {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 12px 24px;
    background: transparent;
    color: var(--bone-50);
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    cursor: pointer;
    transition: var(--transition);
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .hero-btn.outlined {
    border-color: rgba(255, 255, 255, 0.5);
  }

  /* ── Imagen producto ── */
  .hero-product {
    position: relative;
    display: none;
    aspect-ratio: 1;
    max-width: 460px;
    background: var(--bone-100);
    border: 2px solid rgba(255, 255, 255, 0.08);
    margin: 0 auto;
  }

  .hero-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
  }

  .stamp-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
  }

  @media (hover: hover) {
    .hero-btn:hover {
      background: rgba(255, 255, 255, 0.07);
      border-color: rgba(255, 255, 255, 0.5);
    }

    .hero-btn.outlined:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--bone-50);
    }
  }

  @media (min-width: 750px) {
    .hero-section {
      padding: 96px 0 88px;
    }

    .hero-inner {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 56px;
    }

    .hero-product {
      display: block;
    }
  }
</style>
