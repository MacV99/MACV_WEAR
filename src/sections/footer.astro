---

<footer>
  <div class="container footer-grid">
    <div class="col-brand">
      <img src="/img/logo-horizontal.avif" alt="MacV Wear" class="logo" />
      <p class="tagline">Ropa interior masculina<br />sin compromisos.</p>
      <div class="socials flex-row">
        <a
          href="https://wa.me/57"
          aria-label="WhatsApp"
          target="_blank"
          rel="noopener"
        >
          <i class="bi bi-whatsapp"></i>
        </a>
        <a
          href="https://instagram.com/macvwear"
          aria-label="Instagram"
          target="_blank"
          rel="noopener"
        >
          <i class="bi bi-instagram"></i>
        </a>
        <a
          href="https://tiktok.com/@macvwear"
          aria-label="TikTok"
          target="_blank"
          rel="noopener"
        >
          <i class="bi bi-tiktok"></i>
        </a>
      </div>
    </div>

    <div class="col">
      <span class="col-title">Navegación</span>
      <a href="/">Inicio</a>
      <a href="/tienda">Tienda</a>
    </div>

    <div class="col">
      <span class="col-title">Contacto</span>
      <a href="mailto:hola@macvwear.com">hola@macvwear.com</a>
      <a href="https://wa.me/57" target="_blank" rel="noopener">WhatsApp</a>
      <span class="address">Colombia</span>
    </div>

    <div class="col">
      <span class="col-title">Legal</span>
      <a href="#">Política de privacidad</a>
      <a href="#">Términos y condiciones</a>
      <a href="#">Devoluciones</a>
    </div>
  </div>

  <div class="container footer-bottom flex-row">
    <span class="copy">©2025 MacV Wear — Todos los derechos reservados.</span>
    <span class="made">Hecho en Colombia 🇨🇴</span>
  </div>
</footer>

<style>
  footer {
    background: var(--carbon-900);
    color: var(--bone-300);
    padding: 64px 0 0;
    border-top: 2px solid var(--carbon-800);
    gap: 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: 48px;
  }

  /* ── Columna brand ── */
  .col-brand {
    display: grid;
    grid-template-columns: 1fr;
    align-items: start;
    gap: 16px;
  }

  .logo {
    height: 32px;
    width: auto;
    filter: invert(1);
    opacity: 0.88;
  }

  .tagline {
    color: var(--carbon-300);
    font-size: 13px;
    line-height: 1.6;
  }

  .socials {
    gap: 0;
    justify-content: flex-start;
    border: 1px solid rgba(255, 255, 255, 0.15);
    width: fit-content;
  }

  .socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 14px;
    color: var(--bone-300);
    font-size: 17px;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
    transition: var(--transition);
  }

  .socials a:last-child {
    border-right: none;
  }

  /* ── Columnas secundarias ── */
  .col {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .col-title {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--carbon-300);
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    width: 100%;
  }

  .col a,
  .address {
    font-size: 13px;
    color: var(--bone-400);
    transition: var(--transition);
  }

  .address {
    color: var(--carbon-300);
  }

  /* ── Barra inferior ── */
  .footer-bottom {
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 18px;
    padding-bottom: 18px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .copy,
  .made {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: var(--carbon-300);
  }

  @media (hover: hover) {
    .socials a:hover {
      background: rgba(255, 255, 255, 0.06);
      color: var(--bone-50);
    }

    .col a:hover {
      color: var(--bone-50);
    }
  }

  @media (min-width: 750px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 32px;
    }
  }
</style>
