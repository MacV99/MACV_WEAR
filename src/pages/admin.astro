---
import '../styles/global.css';
import '../styles/project.css';
import { API_URL } from '../scripts/admin-config';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel — MacV Wear</title>
    <link rel="icon" type="image/avif" href="/img/logo-mark.avif" />
    <link rel="apple-touch-icon" href="/img/logo-mark.avif" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- Marca la sesión ANTES de pintar → sin parpadeo del login al recargar. -->
    <script is:inline>
      if (localStorage.getItem('macv_admin_pass')) document.documentElement.classList.add('authed');
    </script>
  </head>
  <body>
    <!-- LOGIN -->
    <div id="login" class="login">
      <form id="login-form" class="login-card">
        <span class="login-mark"><img src="/img/logo-mark.avif" alt="MacV Wear" width="76" height="76" /></span>
        <div class="login-logo">MacV<span>·</span>Panel</div>
        <p class="login-sub">Gestión de inventario y ventas</p>
        <div class="login-field">
          <i class="bi bi-lock-fill login-field-ico"></i>
          <input id="login-pin" class="login-pin" type="password" inputmode="numeric" pattern="[0-9]*" maxlength="4" placeholder="• • • •" autocomplete="off" aria-label="PIN de acceso" />
          <button type="button" id="login-eye" class="login-eye" aria-label="Mostrar u ocultar PIN"><i class="bi bi-eye-fill"></i></button>
        </div>
        <button type="submit" class="btn-primary login-btn">Entrar <i class="bi bi-arrow-right-short"></i></button>
        <span id="login-err" class="login-err" hidden><i class="bi bi-exclamation-circle-fill"></i> <span></span></span>
        <a href="/" class="login-back"><i class="bi bi-arrow-left-short"></i> Volver a la tienda</a>
      </form>
    </div>

    <!-- APP -->
    <div id="app" class="app" hidden>
      <aside class="sidebar">
        <div class="sidebar-head">
          <div class="brand"><img class="brand-mark" src="/img/logo-mark.avif" alt="" width="28" height="28" />MacV<span>·</span>Panel</div>
          <div class="sidebar-actions">
            <a href="/" class="icon-btn" title="Volver a la tienda"><i class="bi bi-shop"></i></a>
            <button id="btn-refresh" class="icon-btn" title="Actualizar"><i class="bi bi-arrow-clockwise"></i></button>
            <button id="btn-logout" class="icon-btn" title="Salir"><i class="bi bi-box-arrow-right"></i></button>
          </div>
        </div>
        <nav class="side-nav">
          <button class="tab" data-tab="inventario"><i class="bi bi-box-seam"></i> Inventario</button>
          <button class="tab active" data-tab="ventas"><i class="bi bi-receipt"></i> Ventas</button>
          <button class="tab" data-tab="clientes"><i class="bi bi-people"></i> Clientes</button>
        </nav>
      </aside>

      <div class="main">
        <!-- KPIs -->
        <section class="kpis" id="kpis"></section>

        <main class="content">
        <!-- INVENTARIO -->
        <section class="panel" data-panel="inventario">
          <div class="panel-head">
            <h2>Inventario</h2>
            <button id="btn-nuevo" class="btn-primary"><i class="bi bi-plus-lg"></i> Nuevo producto</button>
          </div>
          <input id="inv-search" class="field search wide-search" type="search" placeholder="Buscar…" />
          <div id="inv-body" class="card-list"></div>
        </section>

        <!-- VENTAS -->
        <section class="panel active" data-panel="ventas">
          <div class="panel-head">
            <h2>Ventas</h2>
            <button id="btn-add-venta" class="btn-primary"><i class="bi bi-plus-lg"></i> Agregar venta</button>
          </div>
          <input id="ventas-search" class="field search wide-search" type="search" placeholder="Buscar cliente, producto…" />
          <div class="seg" id="ventas-filtro">
            <button class="seg-btn active" type="button" data-estado="todas">Todas</button>
            <button class="seg-btn" type="button" data-estado="pendiente">Pendientes</button>
            <button class="seg-btn" type="button" data-estado="pagado">Pagadas</button>
          </div>
          <div id="ventas-body" class="card-list"></div>
        </section>

        <!-- CLIENTES -->
        <section class="panel" data-panel="clientes">
          <div class="panel-head"><h2>Clientes</h2></div>
          <input id="cli-search" class="field search wide-search" type="search" placeholder="Buscar cliente o producto…" />
          <div id="cli-body" class="card-list"></div>
        </section>
        </main>
      </div>
    </div>

    <div id="modal-root" class="modal-root"></div>
    <div id="pill" class="pill"></div>

    <script define:vars={{ API_URL }}>
      // ─── estado ────────────────────────────────────────────────────────────
      // PIN numérico de acceso (puerta del panel). El backend usa su propia clave.
      const PIN = '9908';
      const BACKEND_PASS = 'macv2024';   // clave real del GAS — debe coincidir con ADMIN_PASSWORD en Code.gs
      const SS_PASS = 'macv_admin_pass';
      const SS_DATA = 'macv_admin_data';
      let PASS = localStorage.getItem(SS_PASS) || '';

      // Caché local (stale-while-revalidate): al recargar pintamos lo último
      // conocido al instante y refrescamos del servidor en segundo plano.
      function loadCache() {
        try { const raw = localStorage.getItem(SS_DATA); return raw ? JSON.parse(raw) : null; }
        catch { return null; }
      }
      function saveCache() {
        if (!DATA.productos.length && !DATA.ventas.length) return;   // no pisar con vacío
        try { localStorage.setItem(SS_DATA, JSON.stringify(DATA)); } catch {}
      }

      let DATA = loadCache() || { productos: [], ventas: [] };
      let cart = [];

      const $ = (s, r = document) => r.querySelector(s);
      const fmt = (n) => '$ ' + (Number(n) || 0).toLocaleString('es-CO');
      const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
      const keyOf = (p) => `${p.producto}|${p.marca}|${p.color}|${p.talla}`;
      // Estado de pago de una venta: solo 'pendiente' explícito cuenta; vacío/histórico = 'pagado'.
      const estadoDe = (v) => String(v.estado || '').toLowerCase() === 'pendiente' ? 'pendiente' : 'pagado';
      const thumb = (p) => p.imagen
        ? `<img src="${esc(p.imagen)}" alt="${esc(p.marca)}" loading="lazy" onerror="this.replaceWith(Object.assign(document.createElement('span'),{className:'thumb-fb',textContent:'${esc((p.marca || p.producto || 'M')[0].toUpperCase())}'}))">`
        : `<span class="thumb-fb">${esc((p.marca || p.producto || 'M')[0].toUpperCase())}</span>`;

      // ─── red ───────────────────────────────────────────────────────────────
      // Log con marca de tiempo para depurar en la consola del navegador.
      const log  = (...a) => console.log('%c[MacV]', 'color:#B0291F;font-weight:700', ...a);
      const logErr = (label, err, extra) => console.error('%c[MacV] ✗ ' + label, 'color:#B0291F;font-weight:700', err, extra || '');

      function fetchJSONP(url) {
        return new Promise((resolve, reject) => {
          const cb = '_cb_' + Date.now() + Math.floor(Math.random() * 1e4);
          const script = document.createElement('script');
          const t0 = performance.now();
          const timer = setTimeout(() => { cleanup(); logErr('GET timeout (15s)', url); reject(new Error('Tiempo de espera agotado (red lenta o URL mala)')); }, 15000);
          function cleanup() { clearTimeout(timer); delete window[cb]; script.remove(); }
          window[cb] = (d) => { cleanup(); log('GET ok', `${Math.round(performance.now() - t0)}ms`, d); resolve(d); };
          script.onerror = () => { cleanup(); logErr('GET load failed', url); reject(new Error('No cargó el script (revisa la URL del GAS)')); };
          script.src = `${url}?callback=${cb}&_=${Date.now()}`;
          document.head.appendChild(script);
        });
      }

      async function post(payload) {
        const t0 = performance.now();
        log('POST →', payload.action, payload);
        let res, raw, json;
        try {
          res = await fetch(API_URL, {
            method: 'POST', mode: 'cors', redirect: 'follow',
            headers: { 'Content-Type': 'text/plain' },
            body: JSON.stringify({ ...payload, password: PASS }),
          });
          raw = await res.text();
        } catch (netErr) {
          logErr('POST red caída', netErr, { action: payload.action });
          throw new Error('Falló la conexión con el script (red o CORS)');
        }
        try { json = JSON.parse(raw); } catch { json = {}; }
        if (!res.ok || !json.ok) {
          logErr('POST rechazado', json.error || `HTTP ${res.status}`, { action: payload.action, status: res.status, raw: raw.slice(0, 300) });
          throw new Error(json.error || `HTTP ${res.status}`);
        }
        log('POST ok', payload.action, `${Math.round(performance.now() - t0)}ms`, json);
        if (json.data) DATA = json.data;
        return json;
      }

      // ─── pill ──────────────────────────────────────────────────────────────
      function pill(msg, type = 'ok') {
        const el = $('#pill');
        el.textContent = msg;
        el.className = 'pill show ' + type;
        clearTimeout(el._t);
        el._t = setTimeout(() => el.classList.remove('show'), 2600);
      }

      // ─── login ─────────────────────────────────────────────────────────────
      // Valida la clave de verdad (POST ping). Si el script aún no tiene 'ping'
      // (deploy viejo) y la clave es correcta, devuelve "Acción desconocida" →
      // eso confirma que la clave pasó, así que entramos igual.
      async function validarClave() {
        try { await post({ action: 'ping' }); }
        catch (e) { if (!/desconocida/i.test(e.message)) throw e; }
      }

      async function entrar() {
        await validarClave();          // lanza si la clave es incorrecta
        await loadData();
        localStorage.setItem(SS_PASS, PASS);
        $('#login').hidden = true;
        $('#app').hidden = false;
        renderAll();
      }

      $('#login-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const err = $('#login-err');
        const pinInput = $('#login-pin');
        const pin = pinInput.value.trim();
        // Puerta cliente: el PIN debe ser exacto antes de tocar el backend.
        if (pin !== PIN) {
          err.querySelector('span').textContent = 'PIN incorrecto.';
          err.hidden = false;
          pinInput.value = ''; pinInput.focus();
          return;
        }
        PASS = BACKEND_PASS;   // por dentro autenticamos con la clave real del GAS
        const btn = e.target.querySelector('button[type="submit"]');
        err.hidden = true; btn.disabled = true; btn.textContent = 'Entrando…';
        try {
          await entrar();
        } catch (e2) {
          err.querySelector('span').textContent = /clave/i.test(e2.message) ? 'Clave del backend incorrecta.' : 'No se pudo conectar. Revisa la URL del script.';
          err.hidden = false;
        } finally { btn.disabled = false; btn.innerHTML = 'Entrar <i class="bi bi-arrow-right-short"></i>'; }
      });

      // Auto-entrar: en cuanto el PIN esté completo y sea correcto, enviamos solo.
      $('#login-pin').addEventListener('input', () => {
        const inp = $('#login-pin');
        inp.value = inp.value.replace(/\D/g, '');   // solo dígitos
        if (inp.value === PIN) $('#login-form').requestSubmit();
      });

      // Mostrar / ocultar PIN.
      $('#login-eye').addEventListener('click', () => {
        const inp = $('#login-pin');
        const mostrar = inp.type === 'password';
        inp.type = mostrar ? 'text' : 'password';
        $('#login-eye').firstElementChild.className = mostrar ? 'bi bi-eye-slash-fill' : 'bi bi-eye-fill';
        inp.focus();
      });

      $('#btn-logout').addEventListener('click', () => {
        localStorage.removeItem(SS_PASS);
        location.reload();
      });
      $('#btn-refresh').addEventListener('click', async () => {
        await loadData(); renderAll(); pill('Actualizado');
      });

      // ─── carga ─────────────────────────────────────────────────────────────
      async function loadData() {
        const r = await fetchJSONP(API_URL);
        if (!r.ok) throw new Error(r.error || 'Error');
        DATA = { productos: r.productos || [], ventas: r.ventas || [] };
      }

      // helper: POST + refresh + feedback en un paso
      async function submit(payload, okMsg) {
        try { await post(payload); renderAll(); pill(okMsg || 'Listo ✓'); return true; }
        catch (err) {
          logErr(`acción "${payload.action}" falló`, err.message, payload);
          const hint = /desconocida/i.test(err.message) ? ' — re-despliega el script' : '';
          pill(err.message + hint, 'err');
          return false;
        }
      }

      // ─── modales ─────────────────────────────────────────────────────────────
      function closeModal() {
        const root = $('#modal-root');
        root.innerHTML = '';
        root.classList.remove('open');
        document.removeEventListener('keydown', modalEsc);
      }
      function modalEsc(e) { if (e.key === 'Escape') { const root = $('#modal-root'); if (root._reject) root._reject(); closeModal(); } }

      function mountModal(innerHTML) {
        const root = $('#modal-root');
        root.innerHTML = `<div class="modal-backdrop"></div><div class="modal" role="dialog" aria-modal="true">${innerHTML}</div>`;
        root.classList.add('open');
        document.addEventListener('keydown', modalEsc);
        root.querySelector('.modal-backdrop').addEventListener('click', () => { if (root._reject) root._reject(); closeModal(); });
        return root;
      }

      // Form modal → resuelve con {campo:valor} o null si se cancela.
      function modalForm(opts) {
        return new Promise((resolve) => {
          const fieldsHTML = opts.fields.map((f) => {
            if (f.type === 'select') {
              const opts2 = f.options.map((o) => `<option value="${esc(o)}" ${o === f.value ? 'selected' : ''}>${esc(o)}</option>`).join('');
              return `<label class="mfield">${esc(f.label)}<span class="select-wrap"><select name="${f.name}" class="field">${opts2}</select></span></label>`;
            }
            return `<label class="mfield">${esc(f.label)}<input name="${f.name}" class="field" type="${f.type || 'text'}" value="${esc(f.value ?? '')}" ${f.min ? `min="${f.min}"` : ''} ${f.placeholder ? `placeholder="${esc(f.placeholder)}"` : ''} /></label>`;
          }).join('');
          const root = mountModal(`
            <div class="modal-head"><h3>${esc(opts.title)}</h3>${opts.subtitle ? `<p class="modal-sub">${esc(opts.subtitle)}</p>` : ''}</div>
            <form class="modal-body" id="modal-form">${fieldsHTML}</form>
            <div class="modal-foot">
              <button class="btn-ghost" type="button" data-x>Cancelar</button>
              <button class="btn-primary ${opts.danger ? 'danger' : ''}" type="submit" form="modal-form">${esc(opts.confirm || 'Guardar')}</button>
            </div>`);
          const done = (val) => { root._reject = null; resolve(val); closeModal(); };
          root._reject = () => resolve(null);
          root.querySelector('[data-x]').addEventListener('click', () => done(null));
          root.querySelector('#modal-form').addEventListener('submit', (e) => {
            e.preventDefault();
            const out = {};
            new FormData(e.target).forEach((v, k) => out[k] = v);
            done(out);
          });
          // Campos con combobox creable (f.combo = () => array de opciones).
          opts.fields.forEach((f) => {
            if (f.combo) { const i = root.querySelector(`[name="${f.name}"]`); if (i) makeCombobox(i, f.combo); }
          });
          setTimeout(() => root.querySelector('.field')?.focus(), 30);
        });
      }

      // Confirmación → resuelve true/false.
      function modalConfirm(opts) {
        return new Promise((resolve) => {
          const root = mountModal(`
            <div class="modal-head"><h3>${esc(opts.title)}</h3></div>
            <div class="modal-body"><p class="modal-msg">${esc(opts.message)}</p></div>
            <div class="modal-foot">
              <button class="btn-ghost" type="button" data-x>Cancelar</button>
              <button class="btn-primary ${opts.danger ? 'danger' : ''}" type="button" data-ok>${esc(opts.confirm || 'Confirmar')}</button>
            </div>`);
          const done = (val) => { root._reject = null; resolve(val); closeModal(); };
          root._reject = () => resolve(false);
          root.querySelector('[data-x]').addEventListener('click', () => done(false));
          root.querySelector('[data-ok]').addEventListener('click', () => done(true));
        });
      }

      // ─── combobox creable (autocompletar + "crear si no existe") ──────────────
      // Lista de valores únicos, ordenada y sin vacíos.
      const distinct = (arr) => [...new Set(arr.map((x) => String(x ?? '').trim()).filter(Boolean))]
        .sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
      const clientesList = () => distinct(DATA.ventas.map((v) => v.cliente));
      const valoresProducto = (campo) => distinct(DATA.productos.map((p) => p[campo]));

      // Convierte un <input type="text"> en un combobox: filtra las opciones que
      // ya existen y, si lo escrito no coincide con ninguna, ofrece "+ Crear …".
      // No obliga a elegir: el texto nuevo se conserva y se crea al guardar.
      function makeCombobox(input, getOptions) {
        const wrap = document.createElement('div');
        wrap.className = 'combo';
        input.parentNode.insertBefore(wrap, input);
        wrap.appendChild(input);
        input.setAttribute('autocomplete', 'off');
        const menu = document.createElement('div');
        menu.className = 'combo-menu';
        menu.hidden = true;
        wrap.appendChild(menu);
        let active = -1;

        function render() {
          const q = input.value.trim().toLowerCase();
          const all = getOptions();
          const matches = all.filter((o) => o.toLowerCase().includes(q)).slice(0, 8);
          const exact = all.some((o) => o.toLowerCase() === q);
          let html = matches.map((o) => `<button type="button" class="combo-opt" data-val="${esc(o)}">${esc(o)}</button>`).join('');
          const nuevo = input.value.trim();
          if (nuevo && !exact) {
            html += `<button type="button" class="combo-opt combo-create" data-val="${esc(nuevo)}"><i class="bi bi-plus-lg"></i> Crear «<strong>${esc(nuevo)}</strong>»</button>`;
          }
          menu.innerHTML = html;
          menu.hidden = !html;
          active = -1;
        }
        const close = () => { menu.hidden = true; active = -1; };
        const opts = () => [...menu.querySelectorAll('.combo-opt')];

        input.addEventListener('focus', render);
        input.addEventListener('input', render);
        input.addEventListener('keydown', (e) => {
          const list = opts();
          if (e.key === 'ArrowDown') { e.preventDefault(); if (menu.hidden) { render(); return; } active = Math.min(active + 1, list.length - 1); }
          else if (e.key === 'ArrowUp') { e.preventDefault(); active = Math.max(active - 1, 0); }
          else if (e.key === 'Enter') { if (!menu.hidden && active >= 0) { e.preventDefault(); list[active].click(); } close(); return; }
          else if (e.key === 'Escape') { if (!menu.hidden) { e.stopPropagation(); close(); } return; }
          else return;
          list.forEach((o, i) => o.classList.toggle('active', i === active));
        });
        // mousedown (no click) para adelantarnos al blur del input.
        menu.addEventListener('mousedown', (e) => {
          const b = e.target.closest('.combo-opt'); if (!b) return;
          e.preventDefault();
          input.value = b.dataset.val;
          close();
          input.dispatchEvent(new Event('change', { bubbles: true }));
        });
        input.addEventListener('blur', () => setTimeout(close, 150));
        return { close, render };
      }

      // ─── render maestro ──────────────────────────────────────────────────────
      function renderAll() { renderKPIs(); renderInventario(); renderVentas(); renderClientes(); saveCache(); }

      // Skeleton mientras carga la primera vez (aún sin caché).
      function renderSkeleton() {
        $('#kpis').innerHTML = Array.from({ length: 5 }).map(() => '<div class="kpi sk"><span class="sk-box"></span></div>').join('');
        const rows = Array.from({ length: 4 }).map(() => '<div class="sk-card"></div>').join('');
        const vb = $('#ventas-body'); if (vb) vb.innerHTML = rows;
        const ib = $('#inv-body'); if (ib) ib.innerHTML = rows;
      }

      // ─── KPIs ──────────────────────────────────────────────────────────────
      function renderKPIs() {
        const total = DATA.ventas.reduce((a, v) => a + (v.total || 0), 0);
        const pendiente = DATA.ventas.filter((v) => estadoDe(v) === 'pendiente').reduce((a, v) => a + (v.total || 0), 0);
        const unidades = DATA.ventas.reduce((a, v) => a + (v.cantidad || 0), 0);
        const stockTotal = DATA.productos.reduce((a, p) => a + (p.stock || 0), 0);
        const agotados = DATA.productos.filter((p) => (p.stock || 0) <= 0).length;
        const cards = [
          { l: 'Total vendido', v: fmt(total), i: 'cash-stack' },
          { l: 'Por cobrar', v: fmt(pendiente), i: 'hourglass-split', alert: pendiente > 0 },
          { l: 'Unidades vendidas', v: unidades, i: 'bag-check' },
          { l: 'Stock total', v: stockTotal, i: 'box-seam' },
          { l: 'Agotados', v: agotados, i: 'exclamation-triangle' },
        ];
        $('#kpis').innerHTML = cards.map((c) => `
          <div class="kpi${c.alert ? ' alert' : ''}">
            <i class="bi bi-${c.i}"></i>
            <div><span class="kpi-val">${c.v}</span><span class="kpi-lbl">${c.l}</span></div>
          </div>`).join('');
      }

      // ─── tabs ──────────────────────────────────────────────────────────────
      document.querySelectorAll('.tab').forEach((t) => t.addEventListener('click', () => {
        document.querySelectorAll('.tab').forEach((x) => x.classList.remove('active'));
        document.querySelectorAll('.panel').forEach((x) => x.classList.remove('active'));
        t.classList.add('active');
        $(`.panel[data-panel="${t.dataset.tab}"]`).classList.add('active');
      }));

      // ─── AGREGAR VENTA (modal con varios productos) ───────────────────────────
      // Precio real por unidad (lo que de verdad cobras). La tienda muestra otro.
      const PRECIO_REAL = 25000;

      function abrirModalVenta() {
        let items = [];   // { key, marca, color, talla, cantidad, stock }

        const root = mountModal(`
          <div class="modal-head"><h3>Agregar venta</h3></div>
          <div class="modal-body">
            <label class="mfield">Cliente
              <input id="v-cliente" class="field" type="text" placeholder="Nombre del cliente" autocomplete="off" />
            </label>
            <div class="mfield">Estado de pago
              <div class="seg seg--full" id="v-estado">
                <button type="button" class="seg-btn active" data-estado="pagado">Pagada</button>
                <button type="button" class="seg-btn" data-estado="pendiente">Pendiente</button>
              </div>
            </div>
            <div class="mfield">Productos
              <div class="vitem-add">
                <span class="select-wrap"><select id="v-prod" class="field"></select></span>
                <button type="button" id="v-add" class="btn-ghost vitem-addbtn"><i class="bi bi-plus-lg"></i></button>
              </div>
            </div>
            <div id="v-list" class="vitem-list"></div>
            <div class="vitem-total"><span>Total</span><strong id="v-total">$ 0</strong></div>
          </div>
          <div class="modal-foot">
            <button class="btn-ghost" type="button" data-x>Cancelar</button>
            <button class="btn-primary" type="button" id="v-save">Guardar venta</button>
          </div>`);
        root._reject = () => {};

        const sel = root.querySelector('#v-prod');
        const listEl = root.querySelector('#v-list');
        const totalEl = root.querySelector('#v-total');

        // Cliente: combobox creable sobre los clientes de ventas anteriores.
        makeCombobox(root.querySelector('#v-cliente'), clientesList);

        // Estado de pago: toggle de dos botones (Pagada / Pendiente).
        root.querySelector('#v-estado').addEventListener('click', (e) => {
          const b = e.target.closest('.seg-btn'); if (!b) return;
          root.querySelector('#v-estado .seg-btn.active')?.classList.remove('active');
          b.classList.add('active');
        });

        function disponibles() {
          // stock restante descontando lo ya puesto en el modal
          return DATA.productos.map((p) => {
            const enModal = items.filter((it) => it.key === keyOf(p)).reduce((a, it) => a + it.cantidad, 0);
            return { p, libre: (p.stock || 0) - enModal };
          });
        }

        function pintarSelect() {
          const ops = disponibles()
            .filter((d) => d.libre > 0)
            .map((d) => `<option value="${esc(keyOf(d.p))}">${esc(d.p.marca)} · ${esc(d.p.color)} · ${esc(d.p.talla)} (${d.libre} disp)</option>`)
            .join('');
          sel.innerHTML = ops || '<option value="">Sin stock disponible</option>';
        }

        function pintarLista() {
          listEl.innerHTML = items.map((it, i) => `
            <div class="vitem">
              <span class="vitem-name">${esc(it.marca)} · ${esc(it.color)} · ${esc(it.talla)}</span>
              <div class="qty">
                <button type="button" data-act="dec" data-i="${i}">−</button>
                <span>${it.cantidad}</span>
                <button type="button" data-act="inc" data-i="${i}">+</button>
              </div>
              <span class="vitem-sub">${fmt(it.cantidad * PRECIO_REAL)}</span>
              <button type="button" class="vitem-del" data-act="del" data-i="${i}"><i class="bi bi-x-lg"></i></button>
            </div>`).join('');
          const tot = items.reduce((a, it) => a + it.cantidad, 0) * PRECIO_REAL;
          totalEl.textContent = fmt(tot);
          pintarSelect();
        }

        root.querySelector('#v-add').addEventListener('click', () => {
          const key = sel.value;
          if (!key) return;
          const p = DATA.productos.find((x) => keyOf(x) === key);
          const libre = disponibles().find((d) => keyOf(d.p) === key)?.libre ?? 0;
          if (libre <= 0) { pill('Sin stock', 'err'); return; }
          const ex = items.find((it) => it.key === key);
          if (ex) ex.cantidad++;
          else items.push({ key, marca: p.marca, color: p.color, talla: p.talla, producto: p.producto, cantidad: 1 });
          pintarLista();
        });

        listEl.addEventListener('click', (e) => {
          const b = e.target.closest('button'); if (!b) return;
          const i = +b.dataset.i; const act = b.dataset.act;
          if (act === 'del') items.splice(i, 1);
          if (act === 'inc') {
            const libre = disponibles().find((d) => keyOf(d.p) === items[i].key)?.libre ?? 0;
            if (libre <= 0) { pill('Sin stock', 'err'); return; }
            items[i].cantidad++;
          }
          if (act === 'dec') { items[i].cantidad--; if (items[i].cantidad <= 0) items.splice(i, 1); }
          pintarLista();
        });

        root.querySelector('[data-x]').addEventListener('click', closeModal);

        root.querySelector('#v-save').addEventListener('click', async () => {
          if (!items.length) { pill('Agrega al menos un producto', 'err'); return; }
          const btn = root.querySelector('#v-save');
          btn.disabled = true; btn.textContent = 'Guardando…';
          const payloadItems = items.map((it) => ({
            producto: it.producto, marca: it.marca, color: it.color, talla: it.talla,
            cantidad: it.cantidad, precio: PRECIO_REAL,
          }));
          const ok = await submit({
            action: 'sale', items: payloadItems,
            cliente: root.querySelector('#v-cliente').value.trim(),
            estado: root.querySelector('#v-estado .seg-btn.active').dataset.estado,
          }, 'Venta registrada ✓');
          if (ok) closeModal();
          else { btn.disabled = false; btn.textContent = 'Guardar venta'; }
        });

        pintarLista();
        setTimeout(() => root.querySelector('#v-cliente')?.focus(), 30);
      }

      $('#btn-add-venta').addEventListener('click', abrirModalVenta);

      // ─── INVENTARIO ──────────────────────────────────────────────────────────
      function renderInventario() {
        const q = ($('#inv-search').value || '').toLowerCase();
        const list = DATA.productos.filter((p) => !q || [p.producto, p.marca, p.color, p.talla].join(' ').toLowerCase().includes(q));
        $('#inv-body').innerHTML = list.map((p) => {
          const k = esc(keyOf(p));
          const oos = (p.stock || 0) <= 0;
          return `
            <article class="inv-card${oos ? ' oos' : ''}" data-key="${k}">
              <div class="inv-thumb">${thumb(p)}</div>
              <div class="inv-main">
                <div class="inv-title"><span class="inv-marca">${esc(p.marca)}</span></div>
                <div class="inv-sub">${esc(p.producto)} · ${esc(p.color)} · ${esc(p.talla)}</div>
                <div class="inv-nums">
                  <span class="inv-units${oos ? ' zero' : ''}">Disponibles <b>${p.stock}</b></span>
                  <span>Vendidos <b>${p.vendidos}</b></span>
                </div>
              </div>
              <div class="inv-actions">
                <button class="mini" data-act="addstock" title="Agregar stock"><i class="bi bi-plus-lg"></i></button>
                <button class="mini" data-act="edit" title="Editar"><i class="bi bi-pencil"></i></button>
                <button class="mini danger" data-act="del" title="Eliminar"><i class="bi bi-trash"></i></button>
              </div>
            </article>`;
        }).join('') || '<p class="empty">Sin productos.</p>';
      }
      $('#inv-search').addEventListener('input', renderInventario);

      $('#inv-body').addEventListener('click', async (e) => {
        const b = e.target.closest('button'); if (!b) return;
        const card = b.closest('.inv-card');
        const p = DATA.productos.find((x) => keyOf(x) === card.dataset.key);
        if (!p) return;
        const act = b.dataset.act;
        const ref = `${p.marca} · ${p.color} · ${p.talla}`;
        const keyObj = { producto: p.producto, marca: p.marca, color: p.color, talla: p.talla };

        if (act === 'addstock') {
          const v = await modalForm({
            title: 'Agregar stock', subtitle: ref, confirm: 'Agregar',
            fields: [{ name: 'cantidad', label: 'Unidades a sumar', type: 'number', value: '10', min: '1' }],
          });
          if (!v) return;
          const cant = parseInt(v.cantidad, 10);
          if (!cant) return;
          await submit({ action: 'add_stock', ...keyObj, cantidad: cant }, 'Stock agregado ✓');
        }

        if (act === 'edit') {
          const v = await modalForm({
            title: 'Editar producto', subtitle: ref, confirm: 'Guardar',
            fields: [
              { name: 'precio', label: 'Precio tienda', type: 'number', value: p.precio },
              { name: 'imagen', label: 'Imagen (URL)', type: 'text', value: p.imagen },
            ],
          });
          if (!v) return;
          await submit({ action: 'update_product', key: keyObj, fields: v }, 'Actualizado ✓');
        }

        if (act === 'del') {
          const ok = await modalConfirm({ title: 'Eliminar producto', message: `¿Eliminar ${ref}? Esto borra la fila del inventario.`, confirm: 'Eliminar', danger: true });
          if (!ok) return;
          await submit({ action: 'delete_product', ...keyObj }, 'Eliminado');
        }
      });

      // ─── NUEVO PRODUCTO (modal desde Inventario) ─────────────────────────────
      // Cada campo de texto es un combobox creable que reutiliza los valores ya
      // existentes del inventario (marcas, colores, tallas, categorías…).
      async function abrirModalNuevo() {
        const o = await modalForm({
          title: 'Nuevo producto', confirm: 'Crear producto',
          fields: [
            { name: 'producto', label: 'Producto', combo: () => valoresProducto('producto'), placeholder: 'Boxer' },
            { name: 'marca', label: 'Marca', combo: () => valoresProducto('marca'), placeholder: 'Nike' },
            { name: 'color', label: 'Color', combo: () => valoresProducto('color'), placeholder: 'Negro' },
            { name: 'talla', label: 'Talla', combo: () => valoresProducto('talla'), placeholder: 'XL' },
            { name: 'precio', label: 'Precio tienda', type: 'number', placeholder: '30000' },
            { name: 'stock_inicial', label: 'Stock inicial', type: 'number', placeholder: '10' },
            { name: 'categoria', label: 'Categoría', combo: () => valoresProducto('categoria'), placeholder: 'Ropa interior' },
            { name: 'imagen', label: 'Imagen (URL)', placeholder: 'https://…' },
          ],
        });
        if (!o) return;
        if (!o.producto || !o.marca || !o.color || !o.talla || !o.precio) {
          pill('Completa producto, marca, color, talla y precio', 'err');
          return;
        }
        // ¿Ya existe esta combinación producto/marca/color/talla? (sin distinguir mayúsculas)
        const existente = DATA.productos.find((p) => keyOf(p).toLowerCase() === keyOf(o).toLowerCase());
        const cant = parseInt(o.stock_inicial, 10) || 0;
        if (existente) {
          // Ya existe → solo sumamos el stock indicado, no creamos fila nueva.
          await submit({ action: 'add_stock', producto: existente.producto, marca: existente.marca, color: existente.color, talla: existente.talla, cantidad: cant }, `Ya existía — +${cant} al stock ✓`);
        } else {
          await submit({ action: 'add_product', ...o }, 'Producto creado ✓');
        }
      }
      $('#btn-nuevo').addEventListener('click', abrirModalNuevo);

      // ─── VENTAS ────────────────────────────────────────────────────────────
      function renderVentas() {
        const q = ($('#ventas-search')?.value || '').toLowerCase();
        const filtro = $('#ventas-filtro .seg-btn.active')?.dataset.estado || 'todas';
        const v = [...DATA.ventas].reverse()
          .filter((x) => filtro === 'todas' || estadoDe(x) === filtro)
          .filter((x) => !q || [x.cliente, x.producto, x.marca, x.color, x.talla].join(' ').toLowerCase().includes(q));
        $('#ventas-body').innerHTML = v.map((x) => {
          const est = estadoDe(x);
          const pend = est === 'pendiente';
          return `
          <article class="venta-card ${est}" data-id="${esc(x.id)}">
            <div class="venta-head">
              <span class="venta-cliente">${x.cliente ? esc(x.cliente) : '<i>Sin cliente</i>'}</span>
              <span class="venta-total">${fmt(x.total)}</span>
            </div>
            <div class="venta-sub">${esc(x.marca)} · ${esc(x.color)} · ${esc(x.talla)} · ${x.cantidad} u</div>
            <div class="venta-foot">
              <span class="venta-fecha">${esc(x.fecha)}</span>
              <span class="venta-tags">
                <span class="v-estado ${est}">${pend ? 'Pendiente' : 'Pagado'}</span>
                <span class="tag">${x.cantidad} u</span>
              </span>
            </div>
            <div class="venta-actions">
              ${pend
                ? `<button class="mini pay" data-act="pay" title="Marcar pagada"><i class="bi bi-check-lg"></i> Pagar</button>`
                : `<button class="mini" data-act="unpay" title="Marcar pendiente"><i class="bi bi-arrow-counterclockwise"></i></button>`}
              <button class="mini" data-act="edit" title="Editar"><i class="bi bi-pencil"></i></button>
              <button class="mini danger" data-act="del" title="Eliminar"><i class="bi bi-trash"></i></button>
            </div>
          </article>`;
        }).join('') || '<p class="empty">No hay ventas con este filtro.</p>';
      }
      document.addEventListener('input', (e) => { if (e.target.id === 'ventas-search') renderVentas(); });
      // Filtro por estado (segmented control).
      $('#ventas-filtro').addEventListener('click', (e) => {
        const b = e.target.closest('.seg-btn'); if (!b) return;
        $('#ventas-filtro .seg-btn.active')?.classList.remove('active');
        b.classList.add('active');
        renderVentas();
      });

      // ─── CLIENTES ──────────────────────────────────────────────────────────
      // Agrupa las ventas por cliente y resume qué productos compró cada uno.
      // (DATA.ventas viene en orden cronológico, así que la última iteración
      //  de cada cliente es su compra más reciente.)
      function renderClientes() {
        const q = ($('#cli-search')?.value || '').toLowerCase();
        const map = new Map();
        DATA.ventas.forEach((v) => {
          const nombre = String(v.cliente ?? '').trim();
          if (!nombre) return;   // ignoramos ventas sin cliente
          const k = nombre.toLowerCase();
          if (!map.has(k)) map.set(k, { nombre, total: 0, unidades: 0, compras: 0, ultima: '', prods: new Map() });
          const c = map.get(k);
          c.total += v.total || 0;
          c.unidades += v.cantidad || 0;
          c.compras += 1;
          if (v.fecha) c.ultima = v.fecha;   // último en el tiempo (orden cronológico)
          const pk = `${v.marca} · ${v.color} · ${v.talla}`;
          c.prods.set(pk, (c.prods.get(pk) || 0) + (v.cantidad || 0));
        });
        let lista = [...map.values()].sort((a, b) => b.total - a.total);
        if (q) lista = lista.filter((c) =>
          c.nombre.toLowerCase().includes(q) || [...c.prods.keys()].some((p) => p.toLowerCase().includes(q)));

        $('#cli-body').innerHTML = lista.map((c) => {
          const chips = [...c.prods.entries()]
            .map(([p, n]) => `<span class="cli-prod">${esc(p)} <b>×${n}</b></span>`).join('');
          return `
            <article class="cli-card">
              <div class="cli-head">
                <span class="cli-name">${esc(c.nombre)}</span>
                <span class="cli-total">${fmt(c.total)}</span>
              </div>
              <div class="cli-stats">
                <span>Compras <b>${c.compras}</b></span>
                <span>Unidades <b>${c.unidades}</b></span>
                ${c.ultima ? `<span>Última <b>${esc(c.ultima)}</b></span>` : ''}
              </div>
              <div class="cli-prods">${chips}</div>
            </article>`;
        }).join('') || '<p class="empty">Aún no hay clientes registrados.</p>';
      }
      document.addEventListener('input', (e) => { if (e.target.id === 'cli-search') renderClientes(); });

      $('#ventas-body').addEventListener('click', async (e) => {
        const b = e.target.closest('button'); if (!b) return;
        const card = b.closest('.venta-card');
        const x = DATA.ventas.find((v) => String(v.id) === card.dataset.id);
        if (!x) return;
        const ref = `${x.marca} · ${x.color} · ${x.talla}`;

        if (b.dataset.act === 'pay') {
          await submit({ action: 'set_estado', id: x.id, estado: 'pagado' }, 'Marcada como pagada ✓');
          return;
        }
        if (b.dataset.act === 'unpay') {
          await submit({ action: 'set_estado', id: x.id, estado: 'pendiente' }, 'Marcada como pendiente');
          return;
        }

        if (b.dataset.act === 'edit') {
          const v = await modalForm({
            title: 'Editar venta', subtitle: `${ref}${x.cliente ? ' · ' + x.cliente : ''}`, confirm: 'Guardar',
            fields: [
              { name: 'cliente', label: 'Cliente', type: 'text', value: x.cliente, combo: clientesList },
              { name: 'cantidad', label: 'Cantidad', type: 'number', value: x.cantidad, min: '1' },
            ],
          });
          if (!v) return;
          await submit({ action: 'update_venta', id: x.id, fields: v }, 'Venta actualizada ✓');
        }

        if (b.dataset.act === 'del') {
          const ok = await modalConfirm({ title: 'Eliminar venta', message: `¿Eliminar esta venta de ${ref}? Se devolverá ${x.cantidad} u al stock.`, confirm: 'Eliminar', danger: true });
          if (!ok) return;
          await submit({ action: 'delete_venta', id: x.id }, 'Venta eliminada ✓');
        }
      });

      // ─── auto-login si ya hay clave ──────────────────────────────────────────
      (async () => {
        if (!PASS) return;
        const tieneCache = DATA.productos.length > 0 || DATA.ventas.length > 0;
        $('#login').hidden = true; $('#app').hidden = false;
        // Pinta al instante: caché si la hay, si no un skeleton.
        if (tieneCache) renderAll(); else renderSkeleton();
        // Refresca del servidor en segundo plano.
        try {
          await loadData();
          renderAll();
        } catch {
          if (!tieneCache) {
            // Sin caché y sin conexión → volver al login.
            localStorage.removeItem(SS_PASS);
            document.documentElement.classList.remove('authed');
            $('#login').hidden = false; $('#app').hidden = true;
          } else {
            pill('Mostrando datos guardados — sin conexión', 'err');
          }
        }
      })();
    </script>

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      /* Anulamos el flex-center de global.css (pensado para el sitio, no el panel):
         si no, centra el #app y deja franjas a los lados. */
      body {
        margin: 0; display: block;
        font-family: var(--font-body);
        background: var(--bone-100);
        color: var(--fg);
        -webkit-font-smoothing: antialiased;
      }
      /* .content es un <main>: global.css lo vuelve flex-centrado; lo dejamos block. */
      .content { display: block; width: 100%; }

      /* Sesión activa: sin parpadeo del login al recargar (clase puesta en <head>). */
      html.authed #login { display: none; }
      html.authed #app { display: block; }

      /* ── LOGIN ── */
      .login {
        position: fixed; inset: 0;
        display: grid; place-items: center;
        padding: var(--space-4);
        background:
          radial-gradient(120% 90% at 50% -10%, color-mix(in srgb, var(--blood-600) 22%, transparent), transparent 55%),
          var(--carbon-900);
        z-index: 100;
      }
      .login-card {
        display: flex; flex-direction: column; align-items: center; gap: var(--space-3);
        width: 100%; max-width: 360px; text-align: center;
        background: var(--bone-50);
        padding: var(--space-8) var(--space-6) var(--space-7);
        border: 2px solid var(--carbon-900);
        box-shadow: var(--shadow-press);
      }
      .login-mark {
        display: grid; place-items: center;
        width: 92px; height: 92px; margin-bottom: var(--space-1);
        background: var(--carbon-900);
        border: 2px solid var(--carbon-900);
        box-shadow: var(--shadow-press);
      }
      .login-mark img { width: 60px; height: 60px; object-fit: contain; filter: invert(1); }
      .login-logo { font-family: var(--font-display); font-size: 2rem; letter-spacing: .02em; line-height: 1; }
      .login-logo span { color: var(--blood-600); }
      .login-sub { margin: 0 0 var(--space-2); color: var(--fg-muted); font-size: .85rem; }

      .login-field { position: relative; width: 100%; }
      .login-field-ico {
        position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
        color: var(--fg-muted); font-size: .95rem; pointer-events: none;
      }
      .login-field input {
        width: 100%; font-family: var(--font-body); font-size: .95rem;
        padding: 12px 42px; border: 1px solid var(--border-strong);
        background: var(--bone-50); color: var(--fg);
      }
      .login-field input:focus { outline: none; box-shadow: var(--focus-ring); }
      .login-pin {
        text-align: center; font-family: var(--font-mono);
        font-size: 1.5rem; letter-spacing: .5em; padding-inline: 42px 42px;
        text-indent: .5em; /* compensa el letter-spacing del último dígito para centrar */
      }
      .login-pin::placeholder { letter-spacing: .15em; font-size: 1.1rem; opacity: .5; }
      .login-eye {
        position: absolute; right: 4px; top: 50%; transform: translateY(-50%);
        width: 34px; height: 34px; display: grid; place-items: center;
        border: none; background: transparent; color: var(--fg-muted); cursor: pointer; font-size: 1rem;
      }
      .login-btn { width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 2px; }
      .login-btn i { font-size: 1.3rem; }
      .login-err { display: inline-flex; align-items: center; gap: 6px; color: var(--blood-600); font-size: .82rem; }
      .login-back {
        display: inline-flex; align-items: center; gap: 2px;
        margin-top: var(--space-1); color: var(--fg-muted);
        font-size: .82rem; text-decoration: none; transition: var(--transition);
      }
      .login-back i { font-size: 1.15rem; }

      /* ── LAYOUT (móvil-first: sidebar = barra superior; desktop = columna lateral) ── */
      .app { min-height: 100vh; }

      .sidebar {
        position: sticky; top: 0; z-index: 30;
        background: var(--carbon-900); color: var(--bone-50);
        border-bottom: 2px solid var(--blood-600);
      }
      .sidebar-head {
        display: flex; align-items: center; justify-content: space-between; gap: var(--space-4);
        padding: var(--space-3) var(--space-4);
      }
      .brand {
        display: flex; align-items: center; gap: var(--space-2);
        font-family: var(--font-display); font-size: 1.4rem; letter-spacing: .02em; line-height: 1;
      }
      .brand-mark { height: 26px; width: auto; filter: invert(1); }
      .brand span, .login-logo span { color: var(--blood-600); }
      .sidebar-actions { display: flex; gap: var(--space-2); }
      .icon-btn {
        display: inline-flex; align-items: center; justify-content: center;
        background: transparent; border: 1px solid rgba(255,255,255,.25);
        color: var(--bone-50); width: 38px; height: 38px; border-radius: 0;
        cursor: pointer; font-size: 1.05rem; transition: var(--transition); text-decoration: none;
      }

      /* NAV de pestañas */
      .side-nav {
        display: flex; gap: 0; overflow-x: auto;
        border-top: 1px solid rgba(255,255,255,.1);
      }
      .tab {
        flex: 0 0 auto;
        display: inline-flex; align-items: center; gap: 6px;
        background: transparent; border: none; border-bottom: 3px solid transparent;
        padding: var(--space-3) var(--space-4); cursor: pointer;
        font-family: var(--font-body); font-weight: 600; font-size: .9rem;
        color: var(--bone-400); white-space: nowrap; transition: var(--transition);
      }
      .tab i { font-size: 1rem; }
      .tab.active { color: var(--bone-50); border-bottom-color: var(--blood-600); }

      .main { min-width: 0; }

      /* ── KPIs ── */
      .kpis {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-2);
        padding: var(--space-4);
      }
      .kpi {
        display: flex; align-items: center; gap: var(--space-3);
        background: var(--bone-50); border: 1px solid var(--border);
        padding: var(--space-3) var(--space-4); box-shadow: var(--shadow-sm);
      }
      .kpi i { font-size: 1.5rem; color: var(--blood-600); }
      .kpi.alert { border-color: var(--blood-600); border-left-width: 3px; }
      .kpi.alert .kpi-val { color: var(--blood-600); }
      .kpi > div { display: flex; flex-direction: column; min-width: 0; }
      .kpi-val { font-family: var(--font-display); font-size: 1.4rem; line-height: 1.1; }
      .kpi-lbl { font-size: .72rem; color: var(--fg-muted); text-transform: uppercase; letter-spacing: .04em; }

      /* ── PANELS ── */
      .content { padding: var(--space-5) var(--space-4) var(--space-8); }
      /* reset del padding global de <section> (global.css) que aquí no aplica */
      .panel { display: none; padding: 0; }
      .panel.active { display: block; animation: fade .2s ease; }
      @keyframes fade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }
      .panel-head { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; justify-content: space-between; margin-bottom: var(--space-4); }
      .panel-head h2 { font-family: var(--font-display); font-size: 1.5rem; margin: 0; }

      /* ── FIELDS ── */
      .field {
        font-family: var(--font-body); font-size: .92rem;
        padding: 10px 12px; border: 1px solid var(--border-strong);
        background: var(--bone-50); color: var(--fg); width: 100%;
      }
      .field:focus { outline: none; box-shadow: var(--focus-ring); }
      .search { max-width: 320px; }

      /* ── SELECT: quitamos la flecha nativa (va pegada al borde) y ponemos
         una propia con espacio controlado. El wrapper la dibuja con un
         triángulo CSS coloreado con variables. ── */
      .select-wrap { position: relative; display: block; }
      select.field {
        appearance: none; -webkit-appearance: none; -moz-appearance: none;
        padding-right: 36px; cursor: pointer;
      }
      .select-wrap::after {
        content: ''; position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
        width: 0; height: 0; pointer-events: none;
        border-left: 5px solid transparent; border-right: 5px solid transparent;
        border-top: 6px solid var(--fg);
      }

      /* ── COMBOBOX (autocompletar + crear) ── */
      .combo { position: relative; }
      .combo > .field { width: 100%; }
      .combo-menu {
        position: absolute; top: calc(100% + 2px); left: 0; right: 0; z-index: 40;
        max-height: 240px; overflow-y: auto;
        background: var(--bone-50); border: 1px solid var(--carbon-900);
        box-shadow: var(--shadow-md);
      }
      .combo-opt {
        display: flex; align-items: center; gap: 8px; width: 100%; text-align: left;
        padding: 9px 12px; border: none; border-bottom: 1px solid var(--border);
        background: transparent; color: var(--fg); cursor: pointer;
        font-family: var(--font-body); font-size: .9rem;
      }
      .combo-opt:last-child { border-bottom: none; }
      .combo-opt.active { background: var(--bone-200); }
      .combo-create { color: var(--blood-600); font-weight: 600; }
      .combo-create strong { color: var(--fg); }

      .btn-primary {
        display: inline-flex; align-items: center; justify-content: center; gap: 6px; white-space: nowrap;
        font-family: var(--font-body); font-weight: 700; font-size: .92rem;
        padding: 11px 18px; border: 2px solid var(--carbon-900);
        background: var(--blood-600); color: #fff; cursor: pointer;
        transition: var(--transition); box-shadow: var(--shadow-press);
      }
      .btn-primary:disabled { opacity: .6; cursor: default; box-shadow: none; }

      /* ── imágenes / fallback ── */
      .sku-thumb, .inv-thumb {
        display: block; overflow: hidden; background: var(--bone-200);
        border: 1px solid var(--border);
      }
      .sku-thumb img, .inv-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .thumb-fb {
        display: grid; place-items: center; width: 100%; height: 100%;
        font-family: var(--font-display); font-size: 1.5rem; color: var(--carbon-300);
        background: var(--bone-200);
      }

      /* ── SKU GRID (vender) ── */
      .sku-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-3); }
      .sku-card {
        display: flex; flex-direction: column; gap: 4px; text-align: left;
        padding: 0; border: 1px solid var(--border-strong);
        background: var(--bone-50); cursor: pointer; transition: var(--transition); overflow: hidden;
      }
      .sku-card.oos { opacity: .5; cursor: default; }
      .sku-thumb { aspect-ratio: 1 / 1; }
      .sku-marca { font-family: var(--font-display); font-size: 1.05rem; padding: var(--space-2) var(--space-3) 0; }
      .sku-meta { font-size: .74rem; color: var(--fg-muted); padding: 0 var(--space-3); }
      .sku-foot { display: flex; justify-content: space-between; align-items: baseline; padding: 2px var(--space-3) var(--space-3); }
      .sku-precio { font-weight: 700; }
      .sku-stock { font-size: .72rem; color: var(--fg-muted); }

      /* ── CARD LIST (inventario / ventas) ── */
      .card-list { display: grid; grid-template-columns: 1fr; gap: var(--space-3); align-items: start; }

      .inv-card {
        display: grid; grid-template-columns: 60px 1fr auto; gap: var(--space-3);
        align-items: center; padding: var(--space-3);
        background: var(--bone-50); border: 1px solid var(--border-strong);
      }
      .inv-card.oos { background: rgba(176,41,31,.05); }
      .inv-thumb { width: 60px; height: 60px; }
      .inv-main { min-width: 0; }
      .inv-title { display: flex; align-items: center; gap: var(--space-2); justify-content: space-between; }
      .inv-marca { font-family: var(--font-display); font-size: 1.1rem; }
      /* "Disponibles" luce igual que "Vendidos"; solo se pinta de rojo si está agotado. */
      .inv-units.zero, .inv-units.zero b { color: var(--blood-600); }
      .inv-sub { font-size: .76rem; color: var(--fg-muted); margin: 2px 0 6px; }
      .inv-nums { display: flex; flex-wrap: wrap; align-items: center; gap: 6px var(--space-3); font-size: .74rem; color: var(--fg-muted); }
      .inv-nums b { color: var(--fg); }
      .inv-actions { display: flex; flex-direction: column; gap: 6px; }

      .venta-card { padding: var(--space-3) var(--space-4); background: var(--bone-50); border: 1px solid var(--border); border-left: 3px solid var(--olive-600); }
      .venta-actions { display: flex; gap: 6px; justify-content: flex-end; margin-top: var(--space-3); padding-top: var(--space-2); border-top: 1px solid var(--border); }
      .venta-head { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); }
      .venta-cliente { font-family: var(--font-display); font-size: 1.05rem; }
      .venta-cliente i { color: var(--fg-muted); font-weight: 400; }
      .venta-total { font-weight: 700; }
      .venta-sub { font-size: .78rem; color: var(--fg-muted); margin: 2px 0 8px; }
      .venta-foot { display: flex; justify-content: space-between; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
      .venta-fecha { font-family: var(--font-mono); font-size: .72rem; color: var(--fg-muted); }
      .venta-tags { display: flex; align-items: center; gap: 6px; }
      .tag { font-size: .7rem; padding: 2px 8px; background: var(--bone-200); border-radius: 999px; }
      .tag.pos { background: rgba(90,90,46,.15); color: var(--olive-700); font-weight: 700; }

      /* ── ESTADO DE PAGO ── */
      /* borde izquierdo de la tarjeta indica el estado */
      .venta-card.pendiente { border-left-color: var(--blood-600); }
      .v-estado {
        font-family: var(--font-mono); font-size: .68rem; font-weight: 700; letter-spacing: .02em;
        padding: 3px 8px; border: 1px solid; white-space: nowrap;
      }
      .v-estado.pagado { border-color: var(--olive-600); background: rgba(90, 90, 46, .12); color: var(--olive-700); }
      .v-estado.pendiente { border-color: var(--blood-600); background: rgba(176, 41, 31, .1); color: var(--blood-600); }
      /* botón "Pagar": más ancho (lleva texto) y en oliva */
      .mini.pay {
        display: inline-flex; align-items: center; gap: 4px; width: auto; padding: 0 10px;
        font-family: var(--font-body); font-weight: 700; font-size: .78rem;
        border-color: var(--olive-600); color: var(--olive-700);
      }

      /* ── SEGMENTED CONTROL (filtro de estado) ── */
      .seg { display: inline-flex; margin-bottom: var(--space-4); border: 1px solid var(--border-strong); }
      .seg-btn {
        font-family: var(--font-body); font-weight: 600; font-size: .82rem;
        padding: 7px 14px; border: none; border-right: 1px solid var(--border-strong);
        background: var(--bone-50); color: var(--fg-muted); cursor: pointer; transition: var(--transition);
      }
      .seg-btn:last-child { border-right: none; }
      .seg-btn.active { background: var(--carbon-900); color: var(--bone-50); }
      /* variante ancho completo (modal de venta) */
      .seg--full { display: flex; margin-bottom: 0; }
      .seg--full .seg-btn { flex: 1; text-align: center; padding-block: 9px; }

      /* ── CLIENTES ── */
      .cli-card { padding: var(--space-4); background: var(--bone-50); border: 1px solid var(--border-strong); border-left: 3px solid var(--carbon-900); }
      .cli-head { display: flex; justify-content: space-between; align-items: baseline; gap: var(--space-3); }
      .cli-name { font-family: var(--font-display); font-size: 1.2rem; }
      .cli-total { font-weight: 700; }
      .cli-stats { display: flex; flex-wrap: wrap; align-items: center; gap: 6px var(--space-3); font-size: .74rem; color: var(--fg-muted); margin: 4px 0 var(--space-3); }
      .cli-stats b { color: var(--fg); }
      .cli-prods { display: flex; flex-wrap: wrap; gap: var(--space-2); }
      .cli-prod { font-size: .74rem; padding: 4px 9px; background: var(--bone-100); border: 1px solid var(--border); }
      .cli-prod b { color: var(--blood-600); }

      /* ── CART ── */
      .cart {
        position: sticky; bottom: 0; margin-top: var(--space-5);
        background: var(--bone-50); border: 2px solid var(--carbon-900);
        padding: var(--space-4); box-shadow: var(--shadow-md);
      }
      .cart h3 { font-family: var(--font-display); margin: 0 0 var(--space-3); font-size: 1.1rem; }
      .cart-row { display: grid; grid-template-columns: 1fr auto auto auto; gap: var(--space-3); align-items: center; padding: var(--space-2) 0; border-bottom: 1px solid var(--border); font-size: .88rem; }
      .qty { display: flex; align-items: center; gap: var(--space-2); }
      .qty button { width: 26px; height: 26px; border: 1px solid var(--border-strong); background: var(--bone-100); cursor: pointer; font-size: 1rem; }
      .cart-sub { font-weight: 700; min-width: 70px; text-align: right; }
      .cart-del { border: none; background: transparent; color: var(--blood-600); cursor: pointer; font-size: 1.1rem; }
      .cart-foot { display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center; justify-content: flex-end; margin-top: var(--space-3); }
      .cart-foot .field { max-width: 160px; }
      .cart-total { font-size: 1rem; }
      .cart-total strong { font-family: var(--font-display); font-size: 1.3rem; }

      /* ── acciones / mini-botones ── */
      .mini { width: 34px; height: 34px; border: 1px solid var(--border-strong); background: var(--bone-100); cursor: pointer; }
      .mini.danger { color: var(--blood-600); }
      .empty { text-align: center; color: var(--fg-muted); padding: var(--space-6); }

      /* ── SKELETON (carga inicial) ── */
      .kpi.sk { padding: 0; border-color: var(--border); }
      .sk-box, .sk-card {
        position: relative; overflow: hidden;
        background: var(--bone-200); border: 1px solid var(--border);
      }
      .sk-box { display: block; width: 100%; height: 72px; border: none; }
      .sk-card { height: 92px; }
      .sk-box::after, .sk-card::after {
        content: ''; position: absolute; inset: 0; transform: translateX(-100%);
        background: linear-gradient(90deg, transparent, rgba(251, 248, 242, .65), transparent);
      }
      @media (prefers-reduced-motion: no-preference) {
        .sk-box::after, .sk-card::after { animation: sk-shimmer 1.2s ease-in-out infinite; }
      }
      @keyframes sk-shimmer { 100% { transform: translateX(100%); } }

      /* ── MODAL ── */
      .modal-root { display: none; }
      .modal-root.open { display: block; }
      .modal-backdrop { position: fixed; inset: 0; background: var(--modal-backdrop); z-index: 300; animation: fade .15s ease; }
      .modal {
        position: fixed; z-index: 301; left: 50%; top: 50%; transform: translate(-50%, -50%);
        width: calc(100% - 2 * var(--space-4)); max-width: 440px; max-height: 90vh; overflow-y: auto;
        background: var(--bone-50); border: 2px solid var(--carbon-900);
        box-shadow: var(--shadow-md); animation: slideUp .2s ease;
      }
      @keyframes slideUp { from { transform: translate(-50%, -46%); opacity: 0; } to { transform: translate(-50%, -50%); opacity: 1; } }
      .modal-head { padding: var(--space-5) var(--space-5) var(--space-3); }
      .modal-head h3 { font-family: var(--font-display); font-size: 1.4rem; margin: 0; }
      .modal-sub { margin: 4px 0 0; font-size: .82rem; color: var(--fg-muted); }
      .modal-body { padding: 0 var(--space-5); display: flex; flex-direction: column; gap: var(--space-4); }
      .modal-msg { margin: 0; font-size: .92rem; line-height: 1.5; }
      .mfield { display: flex; flex-direction: column; gap: 6px; font-size: .8rem; font-weight: 600; color: var(--fg-muted); }
      .modal-foot { display: flex; gap: var(--space-3); justify-content: flex-end; padding: var(--space-5); }
      .btn-ghost {
        font-family: var(--font-body); font-weight: 600; font-size: .92rem;
        padding: 11px 18px; border: 1px solid var(--border-strong); background: transparent;
        color: var(--fg); cursor: pointer; transition: var(--transition);
      }
      .btn-primary.danger { background: var(--blood-600); border-color: var(--blood-700); }

      /* ── modal Agregar venta ── */
      .vitem-add { display: flex; gap: var(--space-2); }
      .vitem-add .select-wrap { flex: 1; }
      .vitem-addbtn { padding: 0 14px; flex: 0 0 auto; }
      .vitem-list { display: flex; flex-direction: column; gap: var(--space-2); }
      .vitem { display: grid; grid-template-columns: 1fr auto auto auto; gap: var(--space-2); align-items: center; font-size: .85rem; padding: var(--space-2); background: var(--bone-100); border: 1px solid var(--border); }
      .vitem-name { min-width: 0; }
      .vitem-sub { font-weight: 700; min-width: 64px; text-align: right; }
      .vitem-del { border: none; background: transparent; color: var(--blood-600); cursor: pointer; font-size: .9rem; }
      .qty { display: flex; align-items: center; gap: var(--space-2); }
      .qty button { width: 26px; height: 26px; border: 1px solid var(--border-strong); background: var(--bone-50); cursor: pointer; font-size: 1rem; }
      .vitem-total { display: flex; justify-content: space-between; align-items: baseline; padding-top: var(--space-2); border-top: 1px solid var(--border-strong); font-size: .9rem; }
      .vitem-total strong { font-family: var(--font-display); font-size: 1.4rem; }
      .wide-search { max-width: none; margin-bottom: var(--space-4); }

      /* ── PILL ── */
      .pill {
        position: fixed; bottom: 1.5rem; left: 50%; transform: translateX(-50%) translateY(20px);
        padding: .6rem 1.3rem; border-radius: 999px; color: #fff; font-weight: 600; font-size: .88rem;
        opacity: 0; pointer-events: none; transition: all .3s ease; z-index: 200;
      }
      .pill.show { opacity: 1; transform: translateX(-50%) translateY(0); }
      .pill.ok { background: var(--olive-600); }
      .pill.err { background: var(--blood-600); }

      @media (hover: hover) {
        .icon-btn:hover { background: rgba(255,255,255,.12); }
        .btn-primary:hover:not(:disabled) { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--carbon-900); }
        .sku-card:not(.oos):hover { transform: translateY(-2px); box-shadow: var(--shadow-press); }
        .tab:hover:not(.active) { color: var(--bone-50); }
        .mini:hover { background: var(--bone-300); }
        .mini.pay:hover { background: rgba(90, 90, 46, .12); }
        .seg-btn:hover:not(.active) { color: var(--fg); background: var(--bone-100); }
        .btn-ghost:hover { background: var(--bone-200); }
        .combo-opt:hover { background: var(--bone-200); }
        .login-eye:hover { color: var(--fg); }
        .login-back:hover { color: var(--fg); }
      }

      @media (min-width: 750px) {
        /* Sidebar vertical fija a la izquierda + main que llena el resto.
           Incluimos html.authed #app para ganarle a la regla anti-parpadeo. */
        .app, html.authed #app { display: flex; align-items: flex-start; }
        .sidebar {
          width: 232px; flex: 0 0 232px; align-self: stretch;
          min-height: 100vh; height: 100vh;
          display: flex; flex-direction: column;
          border-bottom: none; border-right: 2px solid var(--blood-600);
        }
        .sidebar-head {
          flex-direction: column; align-items: flex-start; gap: var(--space-4);
          padding: var(--space-5) var(--space-5) var(--space-4);
          border-bottom: 1px solid rgba(255,255,255,.1);
        }
        .side-nav { flex-direction: column; overflow: visible; border-top: none; padding-top: var(--space-2); }
        .tab {
          width: 100%; justify-content: flex-start;
          border-bottom: none; border-left: 3px solid transparent;
          padding: var(--space-3) var(--space-5);
        }
        .tab.active { border-bottom: none; border-left-color: var(--blood-600); background: rgba(255,255,255,.06); }

        /* Acciones (tienda/refresh/salir) ancladas al fondo de la sidebar, solas.
           La sidebar es position:sticky → sirve de contenedor para el absolute. */
        .sidebar-actions {
          position: absolute; left: 0; right: 0; bottom: 0;
          justify-content: center; gap: var(--space-3);
          padding: var(--space-4);
        }

        .main { flex: 1 1 auto; min-width: 0; }
        .kpis { grid-template-columns: repeat(5, 1fr); padding-inline: var(--space-6); }
        .content { padding-inline: var(--space-6); }

        /* Cards en grid: varias por fila, aprovechando el ancho */
        .card-list { grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: var(--space-4); }

        .sku-grid { grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); }
        .inv-card { grid-template-columns: 72px 1fr auto; }
        .inv-thumb { width: 72px; height: 72px; }
        .inv-actions { flex-direction: row; }
      }
    </style>
  </body>
</html>
