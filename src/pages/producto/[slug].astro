---
import Layout1 from '../../layouts/Layout1.astro';
import { products } from '../../data/products';
import type { Product } from '../../data/products';

export async function getStaticPaths() {
  return products.map(p => ({
    params: { slug: p.slug },
    props:  { product: p },
  }));
}

interface Props { product: Product; }
const { product } = Astro.props;

const mainColor = product.colors[0];
const related = products.filter(p => p.slug !== product.slug && p.featured).slice(0, 4);
---

<Layout1 title={`${product.name} — MacV Wear`}>
  <section class="pdp-section">
    <div class="container pdp-grid">

      <!-- GALERÍA -->
      <div class="gallery flex-column">
        <div
          class="gallery-main"
          id="gallery-main"
          style={`background: ${mainColor.gradientCss}`}
          data-colors={JSON.stringify(product.colors)}
        ></div>
        <div class="gallery-thumbs flex-row">
          {product.colors.map((c, i) => (
            <button
              class={`thumb${i === 0 ? ' active' : ''}`}
              data-idx={i}
              style={`background: ${c.gradientCss}`}
              aria-label={`Color ${c.name}`}
            ></button>
          ))}
        </div>
      </div>

      <!-- INFO -->
      <div class="pdp-info flex-column">
        <div class="pdp-top flex-column">
          {product.badge && (
            <span class={`badge ${product.badge === 'sale' ? 'blood' : product.badge === 'limited' ? 'olive' : ''}`}>
              {product.badgeLabel ?? product.badge}
            </span>
          )}
          {product.drop && <span class="drop-label">{product.drop}</span>}
          <h1 class="pdp-title">{product.name}</h1>
          <p class="pdp-subtitle">{product.subtitle}</p>
        </div>

        <span class="pdp-price">${product.price.toLocaleString('es-CO')}</span>

        <!-- COLOR -->
        <div class="option-group flex-column">
          <div class="option-label flex-row">
            <span class="option-key">Color</span>
            <span class="option-val" id="selected-color-name">{mainColor.name}</span>
          </div>
          <div class="color-swatches flex-row">
            {product.colors.map((c, i) => (
              <button
                class={`swatch${i === 0 ? ' active' : ''}`}
                data-idx={i}
                data-name={c.name}
                style={`background: ${c.hex}; border-color: ${c.hex}`}
                aria-label={c.name}
                aria-pressed={i === 0 ? 'true' : 'false'}
              ></button>
            ))}
          </div>
        </div>

        <!-- TALLA -->
        <div class="option-group flex-column">
          <div class="option-label flex-row">
            <span class="option-key">Talla</span>
            <span class="option-val" id="selected-size-name">—</span>
          </div>
          <div class="size-pills flex-row">
            {product.sizes.map(s => {
              const oos = product.outOfStock.includes(s);
              return (
                <button
                  class={`size-pill${oos ? ' oos' : ''}`}
                  data-size={s}
                  disabled={oos}
                  aria-label={`Talla ${s}${oos ? ', agotado' : ''}`}
                >{s}</button>
              );
            })}
          </div>
        </div>

        <!-- QTY -->
        <div class="option-group flex-column">
          <div class="option-label flex-row">
            <span class="option-key">Cantidad</span>
          </div>
          <div class="qty-stepper flex-row">
            <button class="qty-btn" id="qty-dec" aria-label="Menos">−</button>
            <input class="qty-input" id="qty-input" type="number" min="1" max="10" value="1" />
            <button class="qty-btn" id="qty-inc" aria-label="Más">+</button>
          </div>
        </div>

        <!-- MATERIAL -->
        <p class="pdp-material"><strong>Material:</strong> {product.material}</p>

        <!-- ACCIONES -->
        <button class="btn full" id="add-to-cart-btn" disabled>
          Selecciona una talla
        </button>

        <!-- DESCRIPCIÓN -->
        <p class="pdp-desc">{product.description}</p>
      </div>
    </div>
  </section>

  {related.length > 0 && (
    <section class="related-section">
      <div class="container">
        <span class="related-eyebrow">También te puede gustar</span>
        <div class="related-grid">
          {related.map(p => (
            <a href={`/producto/${p.slug}`} class="related-card">
              <div class="related-img" style={`background: ${p.colors[0].gradientCss}`}></div>
              <div class="related-info flex-column">
                <span class="related-name">{p.name}</span>
                <span class="related-price">${p.price.toLocaleString('es-CO')}</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout1>

<style>
  .pdp-section {
    background: var(--bg);
    padding: 48px 0 80px;
  }

  .pdp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ── GALERÍA ── */
  .gallery {
    gap: 12px;
    align-items: stretch;
  }

  .gallery-main {
    width: 100%;
    aspect-ratio: 1 / 1.05;
    border: 2px solid var(--carbon-900);
    transition: background 0.2s ease;
  }

  .gallery-thumbs {
    gap: 8px;
    justify-content: flex-start;
  }

  .thumb {
    width: 60px;
    height: 64px;
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: border-color 0.12s ease;
    flex-shrink: 0;
  }

  .thumb.active {
    border: 2px solid var(--carbon-900);
  }

  /* ── INFO ── */
  .pdp-info {
    align-items: flex-start;
    gap: 24px;
  }

  .pdp-top {
    align-items: flex-start;
    gap: 6px;
  }

  .drop-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--carbon-300);
  }

  .pdp-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 6vw, 52px);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--carbon-900);
    letter-spacing: -0.01em;
  }

  .pdp-subtitle {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--carbon-300);
  }

  .pdp-price {
    font-family: var(--font-display-alt);
    font-size: 28px;
    color: var(--carbon-900);
  }

  /* ── OPTIONS ── */
  .option-group {
    align-items: flex-start;
    gap: 10px;
    width: 100%;
  }

  .option-label {
    gap: 8px;
    align-items: baseline;
  }

  .option-key {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--carbon-500);
  }

  .option-val {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--carbon-900);
  }

  .color-swatches {
    gap: 8px;
    justify-content: flex-start;
  }

  .swatch {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid transparent;
    cursor: pointer;
    outline: 2px solid transparent;
    outline-offset: 2px;
    transition: outline-color 0.12s ease;
  }

  .swatch.active {
    outline-color: var(--carbon-900);
  }

  .size-pills {
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-start;
  }

  .size-pill {
    width: 44px;
    height: 44px;
    border-radius: 999px;
    border: 1.5px solid var(--carbon-900);
    background: var(--bone-50);
    color: var(--carbon-900);
    font-family: var(--font-display-alt);
    font-size: 13px;
    font-weight: 900;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .size-pill.active {
    background: var(--carbon-900);
    color: var(--bone-50);
  }

  .size-pill.oos {
    opacity: 0.3;
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .qty-stepper {
    border: 1.5px solid var(--carbon-900);
    gap: 0;
  }

  .qty-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px 16px;
    font-size: 16px;
    color: var(--carbon-900);
    line-height: 1;
    transition: var(--transition);
  }

  .qty-input {
    width: 48px;
    text-align: center;
    border: none;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    background: transparent;
    font-family: var(--font-display-alt);
    font-size: 14px;
    color: var(--carbon-900);
    padding: 10px 0;
  }

  .qty-input:focus { outline: none; }

  .pdp-material {
    font-size: 12px;
    color: var(--carbon-300);
  }

  .pdp-material strong {
    color: var(--carbon-500);
    font-weight: 700;
  }

  #add-to-cart-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
    transform: none;
  }

  .pdp-desc {
    font-size: 14px;
    color: var(--carbon-500);
    line-height: 1.7;
    border-top: 1px solid var(--border);
    padding-top: 20px;
    width: 100%;
  }

  /* ── RELATED ── */
  .related-section {
    background: var(--bone-200);
    padding: 56px 0;
    border-top: 1px solid var(--border);
  }

  .related-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--carbon-300);
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  .related-card {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--carbon-900);
    color: var(--carbon-900);
    transition: var(--transition);
  }

  .related-img {
    aspect-ratio: 1;
    border-bottom: 1.5px solid var(--carbon-900);
  }

  .related-info {
    padding: 10px 12px;
    align-items: flex-start;
    gap: 2px;
  }

  .related-name {
    font-family: var(--font-display-alt);
    font-size: 12px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .related-price {
    font-family: var(--font-display-alt);
    font-size: 13px;
  }

  @media (hover: hover) {
    .thumb:hover { border-color: var(--carbon-900); }
    .size-pill:not(.oos):not(.active):hover {
      background: var(--bone-200);
    }
    .qty-btn:hover { background: var(--bone-200); }
    .related-card:hover { box-shadow: var(--shadow-sm); }
    .related-card:hover .related-name { text-decoration: underline; text-underline-offset: 3px; }
  }

  @media (min-width: 750px) {
    .pdp-grid {
      grid-template-columns: 1.15fr 0.85fr;
      gap: 56px;
    }

    .related-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
</style>

<script define:vars={{ product }}>
  const colors = product.colors;
  let selectedColorIdx = 0;
  let selectedSize = null;

  const mainEl = document.getElementById('gallery-main');
  const colorNameEl = document.getElementById('selected-color-name');
  const sizeNameEl = document.getElementById('selected-size-name');
  const addBtn = document.getElementById('add-to-cart-btn');
  const qtyInput = document.getElementById('qty-input');
  const qtyDec = document.getElementById('qty-dec');
  const qtyInc = document.getElementById('qty-inc');

  function updateGallery(idx) {
    const c = colors[idx];
    mainEl.style.background = c.gradientCss;

    document.querySelectorAll('.thumb').forEach((t, i) => {
      t.classList.toggle('active', i === idx);
    });
    document.querySelectorAll('.swatch').forEach((s, i) => {
      s.classList.toggle('active', i === idx);
      s.setAttribute('aria-pressed', String(i === idx));
    });

    colorNameEl.textContent = c.name;
    selectedColorIdx = idx;
  }

  function updateAddBtn() {
    if (selectedSize) {
      addBtn.disabled = false;
      addBtn.textContent = 'Añadir al carrito';
    } else {
      addBtn.disabled = true;
      addBtn.textContent = 'Selecciona una talla';
    }
  }

  document.querySelectorAll('.thumb').forEach((btn, i) => {
    btn.addEventListener('click', () => updateGallery(i));
  });

  document.querySelectorAll('.swatch').forEach((btn, i) => {
    btn.addEventListener('click', () => updateGallery(i));
  });

  document.querySelectorAll('.size-pill:not(.oos)').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.size-pill').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      selectedSize = btn.dataset.size;
      sizeNameEl.textContent = selectedSize;
      updateAddBtn();
    });
  });

  qtyDec.addEventListener('click', () => {
    const v = parseInt(qtyInput.value);
    if (v > 1) qtyInput.value = v - 1;
  });

  qtyInc.addEventListener('click', () => {
    const v = parseInt(qtyInput.value);
    if (v < 10) qtyInput.value = v + 1;
  });

  addBtn.addEventListener('click', () => {
    if (!selectedSize) return;
    const c = colors[selectedColorIdx];
    window.MacVCart.add({
      slug:          product.slug,
      name:          product.name,
      color:         c.id,
      colorName:     c.name,
      colorHex:      c.hex,
      colorGradient: c.gradientCss,
      size:          selectedSize,
      price:         product.price,
      qty:           parseInt(qtyInput.value) || 1,
    });
    window.MacVCart.open();
  });
</script>
