---
import Layout1 from '../layouts/Layout1.astro';
---

<Layout1 title="Tienda — MacV Wear">
  <section class="tienda-hero">
    <div class="container flex-column tienda-hero-inner">
      <span class="eyebrow">Toda la colección</span>
      <h1 class="tienda-title">La Tienda</h1>
    </div>
  </section>

  <section class="tienda-controls">
    <div class="container">
      <div class="search-row flex-row">
        <div class="search-wrap flex-row">
          <i class="bi bi-search search-icon"></i>
          <input
            id="tienda-search"
            type="search"
            placeholder="Buscar producto o marca…"
            autocomplete="off"
            class="search-input"
          />
        </div>
        <button id="tienda-clear" class="btn sm ghost" hidden>
          <i class="bi bi-x"></i> Limpiar
        </button>
      </div>

      <div id="tienda-filters" class="tienda-filters">
        <div class="filter-group">
          <span class="filter-label">Marca</span>
          <div id="filter-brand" class="filter-chips-row"></div>
        </div>
        <div class="filter-group">
          <span class="filter-label">Talla</span>
          <div id="filter-size" class="filter-chips-row"></div>
        </div>
        <div class="filter-group">
          <span class="filter-label">Color</span>
          <div id="filter-color" class="filter-chips-row"></div>
        </div>
        <div class="filter-group">
          <span class="filter-label">Estado</span>
          <div class="filter-chips-row">
            <button id="filter-stock" class="filter-chip">Solo disponibles</button>
          </div>
        </div>
      </div>

      <div class="grid-meta flex-row">
        <span id="tienda-count" class="grid-count">Cargando…</span>
      </div>
    </div>
  </section>

  <section class="tienda-grid-section">
    <div class="container">
      <div id="tienda-grid" class="tienda-grid"></div>
    </div>
  </section>
</Layout1>

<style>
  /* ── hero ── */
  .tienda-hero {
    background: var(--carbon-900);
    padding: 56px 0 48px;
    border-bottom: 2px solid var(--carbon-800);
  }

  .tienda-hero-inner {
    align-items: flex-start;
    gap: 8px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--carbon-300);
  }

  .tienda-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 8vw, 80px);
    line-height: 0.92;
    text-transform: uppercase;
    color: var(--bone-50);
    letter-spacing: -0.01em;
  }

  /* ── controls ── */
  .tienda-controls {
    background: var(--bone-50);
    padding: 24px 0 0;
    border-bottom: 1.5px solid var(--border);
  }

  .search-row {
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 20px;
  }

  .search-wrap {
    flex: 1;
    gap: 10px;
    justify-content: flex-start;
    border: 1.5px solid var(--carbon-900);
    padding: 0 14px;
    background: var(--bone-100);
  }

  .search-icon {
    color: var(--carbon-300);
    font-size: 14px;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--carbon-900);
    padding: 11px 0;
    outline: none;
  }

  .search-input::placeholder {
    color: var(--carbon-300);
  }

  /* ── filters ── */
  .tienda-filters {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding-bottom: 20px;
  }

  .filter-group {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--carbon-300);
    width: 44px;
    flex-shrink: 0;
  }

  .filter-chips-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .filter-chip {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 5px 12px;
    background: transparent;
    color: var(--carbon-500);
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: var(--transition);
  }

  .filter-chip.active {
    background: var(--carbon-900);
    color: var(--bone-50);
    border-color: var(--carbon-900);
  }

  /* ── meta ── */
  .grid-meta {
    justify-content: flex-start;
    padding: 14px 0;
    border-top: 1px solid var(--border);
  }

  .grid-count {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--carbon-300);
  }

  /* ── grid ── */
  .tienda-grid-section {
    background: var(--bg);
    padding: 32px 0 80px;
  }

  .tienda-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media (hover: hover) {
    .filter-chip:hover:not(.active) {
      border-color: var(--carbon-900);
      color: var(--carbon-900);
    }
  }

  @media (min-width: 750px) {
    .tienda-filters {
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 16px 24px;
    }

    .filter-label {
      width: auto;
    }

    .filter-group {
      flex-wrap: nowrap;
    }

    .tienda-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
  }
</style>

<style is:global>
  /* ── sheet cards ── */
  .sheet-card {
    display: flex;
    flex-direction: column;
    border: 1.5px solid var(--carbon-900);
    animation: fadeInUp 0.3s ease-out both;
  }

  .sheet-card.oos {
    opacity: 0.65;
  }

  .sc-visual {
    position: relative;
    aspect-ratio: 1 / 1.05;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sc-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sc-initial {
    font-family: var(--font-display);
    font-size: clamp(48px, 10vw, 72px);
    color: var(--carbon-900);
    opacity: 0.15;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sc-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 1;
  }

  .sc-info {
    padding: 12px 14px;
    border-top: 1.5px solid var(--carbon-900);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sc-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
  }

  .sc-name {
    font-family: var(--font-display-alt);
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--carbon-900);
  }

  .sc-price {
    font-family: var(--font-display-alt);
    font-size: 13px;
    color: var(--carbon-900);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sc-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--carbon-300);
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .sc-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1.5px solid rgba(10, 9, 8, 0.25);
    flex-shrink: 0;
  }

  .sc-add {
    margin-top: 10px;
  }

  .sc-add:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
  }

  /* ── skeleton ── */
  .sk-card {
    border: 1.5px solid var(--border);
    display: flex;
    flex-direction: column;
    animation: shimmer 1.4s ease-in-out infinite;
  }

  .sk-visual {
    aspect-ratio: 1 / 1.05;
    background: var(--bone-200);
  }

  .sk-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    border-top: 1.5px solid var(--border);
  }

  .sk-line {
    height: 10px;
    background: var(--bone-300);
    border-radius: 2px;
  }

  @keyframes shimmer {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* ── empty / error ── */
  .sheet-empty {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 64px 0;
    text-align: center;
  }

  .sheet-empty-msg {
    grid-column: 1 / -1;
    text-align: center;
    padding: 64px 0;
    color: var(--carbon-300);
  }

  @media (hover: hover) {
    .sheet-card:hover {
      box-shadow: var(--shadow-sm);
    }
  }
</style>

<script>
  import { initSheetProducts } from '../scripts/sheet-products.ts';
  initSheetProducts();
</script>
