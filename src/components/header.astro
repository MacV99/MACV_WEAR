---
import Navbar from "../components/navbar.astro";
---

<header class="flex-row">
  <a href="/" class="logo-link" aria-label="MacV Wear - Inicio">
    <img src="/img/logo-horizontal.avif" alt="MacV Wear" class="logo" />
  </a>
  <Navbar />
  <div class="header-actions flex-row">
    <button class="cart-btn flex-row" id="open-cart-btn" aria-label="Abrir carrito">
      <i class="bi bi-bag"></i>
      <span class="cart-count" id="header-cart-count" hidden>0</span>
    </button>
  </div>
</header>

<style>
  header {
    justify-content: space-between;
    position: sticky;
    top: 0;
    background: var(--carbon-900);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    width: 100%;
    height: 64px;
    padding: 0 20px;
    z-index: 50;
  }

  .logo-link {
    display: flex;
    align-items: center;
    height: 100%;
    flex-shrink: 0;
  }

  .logo {
    height: 40px;
    width: auto;
    filter: invert(1);
    border-radius: 0;
  }

  .header-actions {
    gap: 8px;
    flex-shrink: 0;
  }

  .cart-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--bone-300);
    font-size: 22px;
    padding: 8px;
    gap: 0;
    transition: color 0.12s ease-out;
  }

  .cart-count {
    position: absolute;
    top: 2px;
    right: 2px;
    background: var(--blood-600);
    color: var(--bone-50);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 9px;
    min-width: 16px;
    height: 16px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 3px;
    line-height: 1;
  }

  @media (hover: hover) {
    .cart-btn:hover {
      color: var(--bone-50);
    }
  }

  @media (min-width: 750px) {
    header {
      padding: 0 32px;
    }
  }
</style>

<script>
  import '../scripts/cart-store.ts';

  const countEl = document.getElementById('header-cart-count');
  const openBtn = document.getElementById('open-cart-btn');

  function updateCount() {
    const n = window.MacVCart.getCount();
    if (countEl) {
      countEl.textContent = String(n);
      countEl.hidden = n === 0;
    }
  }

  openBtn?.addEventListener('click', () => window.MacVCart.open());
  window.addEventListener('cart:updated', updateCount);
  updateCount();
</script>
