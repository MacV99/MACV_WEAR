<nav class="flex-row" aria-label="Menú principal">
  <i class="bi bi-list open-nav" role="button" tabindex="0" aria-label="Abrir menú" aria-expanded="false"></i>

  <div class="flex-column" id="nav-overlay">
    <i class="bi bi-x-lg close-nav" role="button" tabindex="0" aria-label="Cerrar menú"></i>
    <a href="/">Inicio</a>
    <a href="/tienda">Tienda</a>
  </div>
</nav>

<style>
  nav {
    flex: 1;
    justify-content: flex-end;
    padding: 0 16px;
  }

  .open-nav {
    font-size: 26px;
    cursor: pointer;
    color: var(--bone-300);
    padding: 4px;
  }

  #nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    gap: 6%;
    background-color: var(--carbon-900);
    z-index: 200;
  }

  #nav-overlay.open {
    display: flex;
  }

  .close-nav {
    position: absolute;
    top: 20px;
    right: 20px;
    font-size: 22px;
    cursor: pointer;
    color: var(--bone-300);
    padding: 8px;
    border: 1px solid rgba(255,255,255,0.15);
  }

  #nav-overlay a {
    font-family: var(--font-display-alt);
    font-size: 22px;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--bone-50);
    padding: 10px 24px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    width: 220px;
    text-align: center;
    transition: var(--transition);
  }

  @media (hover: hover) {
    .open-nav:hover {
      color: var(--bone-50);
    }

    #nav-overlay a:hover {
      background: rgba(255, 255, 255, 0.06);
      border-color: rgba(255, 255, 255, 0.3);
    }
  }

  @media (min-width: 750px) {
    .open-nav {
      display: none;
    }

    #nav-overlay {
      display: flex;
      position: static;
      flex-direction: row;
      gap: 4px;
      background: transparent;
    }

    .close-nav {
      display: none;
    }

    #nav-overlay a {
      font-family: var(--font-body);
      font-weight: 700;
      font-size: 13px;
      letter-spacing: 0.08em;
      color: var(--bone-300);
      padding: 8px 14px;
      border: none;
      width: auto;
    }
  }
</style>

<script>
  const overlay = document.getElementById('nav-overlay');
  const openBtn = document.querySelector('.open-nav');
  const closeBtn = document.querySelector('.close-nav');

  const open = () => {
    overlay?.classList.add('open');
    document.body.style.overflow = 'hidden';
    openBtn?.setAttribute('aria-expanded', 'true');
  };

  const close = () => {
    overlay?.classList.remove('open');
    document.body.style.overflow = '';
    openBtn?.setAttribute('aria-expanded', 'false');
  };

  openBtn?.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') close();
  });

  overlay?.querySelectorAll('a').forEach(a => a.addEventListener('click', close));
</script>
